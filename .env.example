# Copy to .env and fill in secrets (never commit .env)

# Required for contextual translation
OPENAI_API_KEY=sk-...

# Optional (defaults shown)
TRANSLATE_CONTEXT_MODEL=gpt-5.4-mini
TRANSLATE_CONTEXT_PROMPT_FILE=prompts/translate_context.txt
TRANSLATE_CONTEXT_TIMEOUT=15s

# HTTP server timeouts (must allow LLM latency: WRITE_TIMEOUT >= TRANSLATE_CONTEXT_TIMEOUT + margin)
# READ_TIMEOUT=30s
# WRITE_TIMEOUT=120s
# IDLE_TIMEOUT=120s

# App (optional)
# PORT=8080
# APP_ENV=development
