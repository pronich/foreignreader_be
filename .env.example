# Copy to .env (never commit .env)

# Local `go run` / Makefile: DB on host (compose publishes Postgres on 127.0.0.1:5433 by default)
DATABASE_URL=postgres://foreignreader:YOUR_PASSWORD@localhost:5433/foreignreader?sslmode=disable

# Docker Compose (droplet): set POSTGRES_PASSWORD and matching credentials. Optional DATABASE_URL_COMPOSE if you do not use the default URL built from POSTGRES_*.
# POSTGRES_USER=foreignreader
# POSTGRES_PASSWORD=
# POSTGRES_DB=foreignreader
# POSTGRES_PORT=5433
# DATABASE_URL_COMPOSE=postgres://foreignreader:YOUR_PASSWORD@postgres:5432/foreignreader?sslmode=disable

OPENAI_API_KEY=
TRANSLATE_CONTEXT_MODEL=gpt-5.4-mini
TRANSLATE_CONTEXT_PROMPT_FILE=prompts/translate_context.txt
TRANSLATE_CONTEXT_TIMEOUT=15s

# Public onboarding-only context translation (POST /api/v1/onboarding/translate/context). Must match onboardingToken in the request body. Leave unset to disable that route (503 not_configured).
# ONBOARDING_CONTEXT_TRANSLATE_TOKEN=

# WRITE_TIMEOUT must stay >= TRANSLATE_CONTEXT_TIMEOUT; nginx proxy_*_timeout should match WRITE_TIMEOUT (defaults: nginx/default.conf for prod, nginx/default-dev.conf for dev).
# READ_TIMEOUT=30s
# WRITE_TIMEOUT=120s
# IDLE_TIMEOUT=120s

JWT_SECRET=
GOOGLE_SERVER_CLIENT_ID=

# make compose-up: APP_ENV production|prod uses docker-compose.yml; anything else uses docker-compose.dev.yml (and matching nginx config).
# APP_ENV=production
AUTH_DEV_MODE=false
