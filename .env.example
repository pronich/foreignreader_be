# Copy to .env and fill in secrets (never commit .env)

# Required: PostgreSQL for `go run` / `make migrate-up` (host → published Postgres port, e.g. 5433)
DATABASE_URL=postgres://foreignreader:foreignreader@localhost:5433/foreignreader?sslmode=disable

# Optional: DB URL for services inside Docker Compose (`api` + auto `migrate`). Default reaches host `postgres:5432`.
# Set this if you change POSTGRES_* credentials and need the app container to match.
# DATABASE_URL_COMPOSE=postgres://foreignreader:foreignreader@postgres:5432/foreignreader?sslmode=disable

# Optional: override compose postgres credentials / port (defaults match DATABASE_URL above)
# POSTGRES_USER=foreignreader
# POSTGRES_PASSWORD=foreignreader
# POSTGRES_DB=foreignreader
# POSTGRES_PORT=5432

# Required for contextual translation
OPENAI_API_KEY=sk-...

# Optional (defaults shown)
TRANSLATE_CONTEXT_MODEL=gpt-5.4-mini
TRANSLATE_CONTEXT_PROMPT_FILE=prompts/translate_context.txt
TRANSLATE_CONTEXT_TIMEOUT=15s

# HTTP server timeouts (must allow LLM latency: WRITE_TIMEOUT >= TRANSLATE_CONTEXT_TIMEOUT + margin)
# READ_TIMEOUT=30s
# WRITE_TIMEOUT=120s
# IDLE_TIMEOUT=120s

# App (optional)
# PORT=8080
# APP_ENV=development

# Backend JWT access tokens (required)
JWT_SECRET=change-me

# Google Sign-In: OAuth client ID used as audience when validating ID tokens (iOS “server” / web client ID).
GOOGLE_SERVER_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Dev-only mock Apple/Google login (Postman). Disabled in production (APP_ENV=production).
AUTH_DEV_MODE=true
